index=main source="/var/log/auth.log" ("Failed password" OR "authentication failure")
| rex "from (?<src_ip>\d{1,3}(?:\.\d{1,3}){3})"
| rex "for (invalid user )?(?<username>\w+)"
| stats count as failed_attempts values(username) as targeted_users earliest(_time) as first_seen latest(_time) as last_seen by src_ip
| where failed_attempts >= 5
| convert ctime(first_seen) ctime(last_seen)
| sort - failed_attempts
